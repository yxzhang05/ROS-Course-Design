<launch>
  <!-- ============================================================ -->
  <!-- wulina 多点导航启动文件                                        -->
  <!--                                                              -->
  <!-- 本文件会依次启动：                                             -->
  <!--   1. 机器人底盘、激光雷达等硬件（start_roscar.launch）         -->
  <!--   2. 地图服务器（roscar_map1.yaml）                           -->
  <!--   3. AMCL 自适应蒙特卡洛定位                                   -->
  <!--   4. move_base 路径规划与导航                                  -->
  <!--   5. wulina 多点导航节点                                       -->
  <!--                                                              -->
  <!-- 使用方式：                                                    -->
  <!--   roslaunch wulina multi_point_navigation.launch              -->
  <!--                                                              -->
  <!-- 可选参数（在命令行中用 key:=value 覆盖）：                     -->
  <!--   map_file                  — 地图文件路径（默认：roscar_map3.yaml）       -->
  <!--   loop                      — 是否循环巡逻（true/false，默认：false）      -->
  <!--   loop_count                — 循环次数（loop=true 时有效，0=无限，默认：1）-->
  <!--   goal_timeout              — 单个目标超时秒数（默认：60）                 -->
  <!--   interactive               — 是否启用交互式终端控制（默认：true）         -->
  <!--   rotate_in_place_threshold — XY 距离小于此值（米）时原地旋转（默认：0.05）-->
  <!--   angular_speed             — 原地旋转角速度 rad/s（默认：0.3）            -->
  <!--   yaw_tolerance             — 原地旋转角度容差 rad（默认：0.05）           -->
  <!--   set_initial_pose          — 启动时是否向 AMCL 发布初始位姿（默认：false）-->
  <!--   initial_pose_x            — 初始位姿 X 米（set_initial_pose=true 时有效）-->
  <!--   initial_pose_y            — 初始位姿 Y 米                               -->
  <!--   initial_pose_a            — 初始偏航角 rad                              -->
  <!--   amcl_wait_timeout         — 等待 AMCL 就绪最长秒数（默认：30，≤0=跳过） -->
  <!--   map_rotation_offset       — 导航坐标系相对地图坐标系的逆时针偏角（弧度，默认：0）-->
  <!--                               例：地图偏差 45°，设为 0.7854（即 π/4）        -->
  <!-- ============================================================ -->

  <!-- ===================== -->
  <!-- 1. 导航基础栈           -->
  <!--    复用 start_roscar 包中已有的 navigation.launch            -->
  <!--    该文件会启动：底盘驱动、TF、EKF、激光雷达、地图、AMCL、    -->
  <!--    move_base（全局规划 + TEB 局部规划）                       -->
  <!-- ===================== -->
  <!-- 地图文件，默认使用已建好的 roscar_map3.yaml -->
  <arg name="map_file" default="$(find start_roscar)/map/roscar_map3.yaml"/>
  <include file="$(find start_roscar)/launch/navigation.launch">
    <arg name="map_file" value="$(arg map_file)"/>
  </include>

  <!-- ===================== -->
  <!-- 2. 多点导航节点参数    -->
  <!-- ===================== -->
  <!-- 是否循环执行所有航点（true = 循环，false = 执行一轮后退出） -->
  <arg name="loop"         default="false"/>
  <!-- 循环次数（仅 loop=true 时有效；0 表示无限循环） -->
  <arg name="loop_count"   default="1"/>
  <!-- 单个目标的最长等待时间（秒） -->
  <arg name="goal_timeout" default="60.0"/>
  <!-- 是否启用交互式终端控制（到达每个航点后提示是否继续或修改下一点坐标） -->
  <arg name="interactive"  default="true"/>

  <!-- 原地旋转参数（解决同位置旋转时 XY 漂移问题）-->
  <!-- 相邻航点 XY 距离（米）小于此值时，改用 /cmd_vel 原地旋转代替 move_base -->
  <arg name="rotate_in_place_threshold" default="0.05"/>
  <!-- 原地旋转角速度（rad/s） -->
  <arg name="angular_speed"             default="0.3"/>
  <!-- 原地旋转角度容差（rad），误差小于此值即视为到位 -->
  <arg name="yaw_tolerance"             default="0.05"/>

  <!-- 初始位姿参数（解决 AMCL 初始位姿与建图起点不一致问题）-->
  <!-- 若每次都在固定非原点位置出发，将 set_initial_pose 设为 true 并填写以下坐标 -->
  <arg name="set_initial_pose" default="false"/>
  <arg name="initial_pose_x"   default="0.0"/>
  <arg name="initial_pose_y"   default="0.0"/>
  <arg name="initial_pose_a"   default="0.0"/>
  <!-- 等待 AMCL 就绪的最长时间（秒），解决导航路径奇怪和终点偏差大的问题 -->
  <!-- 设为 ≤0 可跳过等待（仅在 AMCL 已确认就绪时使用）-->
  <arg name="amcl_wait_timeout" default="30.0"/>
  <!-- 坐标系旋转偏差（弧度），解决地图角度偏差问题 -->
  <!-- 表示导航坐标系相对地图坐标系的逆时针旋转角；0 = 两坐标系重合（默认） -->
  <!-- 例：地图偏差 45°（逆时针），则设为 0.7854（π/4） -->
  <arg name="map_rotation_offset" default="0.0"/>

  <!-- ===================== -->
  <!-- 3. 启动多点导航节点    -->
  <!--    脚本路径：wulina/scripts/multi_point_navigation.py        -->
  <!-- ===================== -->
  <node pkg="wulina" type="multi_point_navigation.py"
        name="multi_point_navigation" output="screen">
    <!-- 是否循环导航 -->
    <param name="loop"         value="$(arg loop)"/>
    <!-- 循环次数 -->
    <param name="loop_count"   value="$(arg loop_count)"/>
    <!-- 单目标超时（秒） -->
    <param name="goal_timeout" value="$(arg goal_timeout)"/>
    <!-- 是否启用交互式终端控制 -->
    <param name="interactive"  value="$(arg interactive)"/>
    <!-- 导航坐标系（与建图时使用的 map frame 保持一致） -->
    <param name="map_frame"    value="map"/>
    <!-- 机器人本体坐标系（原地旋转时读取当前朝向使用） -->
    <param name="base_frame"   value="base_footprint"/>

    <!-- 原地旋转参数 -->
    <param name="rotate_in_place_threshold" value="$(arg rotate_in_place_threshold)"/>
    <param name="angular_speed"             value="$(arg angular_speed)"/>
    <param name="yaw_tolerance"             value="$(arg yaw_tolerance)"/>

    <!-- 初始位姿参数 -->
    <param name="set_initial_pose" value="$(arg set_initial_pose)"/>
    <param name="initial_pose_x"   value="$(arg initial_pose_x)"/>
    <param name="initial_pose_y"   value="$(arg initial_pose_y)"/>
    <param name="initial_pose_a"   value="$(arg initial_pose_a)"/>
    <!-- AMCL 就绪等待参数 -->
    <param name="amcl_wait_timeout" value="$(arg amcl_wait_timeout)"/>
    <!-- 坐标系旋转偏差（导航坐标系相对地图坐标系的逆时针偏角，弧度） -->
    <param name="map_rotation_offset" value="$(arg map_rotation_offset)"/>
  </node>

</launch>

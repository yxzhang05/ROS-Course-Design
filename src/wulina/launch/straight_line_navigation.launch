<launch>
  <!-- ============================================================ -->
  <!-- 直线导航启动文件（straight_line_navigation.launch）            -->
  <!--                                                              -->
  <!-- 实现原则：                                                    -->
  <!--   1. 只前进不后退                                             -->
  <!--   2. 转弯与前进不同时进行（先原地转向再直线前进）              -->
  <!--   3. 无障碍物时规划到目标点的直线路径                          -->
  <!--   4. 遇到障碍物时自动回退到 move_base 绕障                    -->
  <!--                                                              -->
  <!-- 本文件会依次启动：                                            -->
  <!--   1. 机器人底盘、激光雷达等硬件（start_roscar.launch）        -->
  <!--   2. 地图服务器（roscar_map1.yaml）                          -->
  <!--   3. AMCL 自适应蒙特卡洛定位                                  -->
  <!--   4. move_base（使用改进版参数，作为绕障 fallback）            -->
  <!--   5. 直线导航节点（straight_line_nav.py）                     -->
  <!--                                                              -->
  <!-- 使用方式：                                                    -->
  <!--   roslaunch wulina straight_line_navigation.launch            -->
  <!--                                                              -->
  <!-- 可选参数（命令行 key:=value 覆盖）：                          -->
  <!--   map_file          — 地图文件路径（默认：roscar_map1.yaml）  -->
  <!--   loop              — 是否循环巡逻（默认：false）             -->
  <!--   loop_count        — 循环次数（loop=true 时有效，默认：1）   -->
  <!--   goal_timeout      — 单个目标超时秒数（默认：60）            -->
  <!--   interactive       — 是否启用交互式控制（默认：true）        -->
  <!--   linear_speed      — 直线前进速度 m/s（默认：0.10）         -->
  <!--   angular_speed     — 原地旋转角速度 rad/s（默认：0.30）      -->
  <!--   yaw_tolerance     — 旋转到位容差 rad（默认：0.05）         -->
  <!--   xy_goal_tolerance — 到达目标点距离容差 m（默认：0.15）      -->
  <!--   obstacle_dist     — 前方障碍物触发阈值 m（默认：0.50）      -->
  <!--   obstacle_angle    — 前方障碍检测半角 rad（默认：0.523~30 deg） -->
  <!--   heading_correct_threshold — 前进中朝向偏差超过此值时停下   -->
  <!--                               重新转向（rad，默认：0.20）     -->
  <!--   set_initial_pose  — 是否自动发布初始位姿（默认：false）     -->
  <!--   initial_pose_x/y/a — 初始位姿（set_initial_pose=true 时）  -->
  <!--   amcl_wait_timeout — 等待 AMCL 就绪最长秒数（默认：30）     -->
  <!--   map_rotation_offset — 导航坐标系相对地图坐标系逆时针偏角                   -->
  <!--                         修正 base_to_laser TF 后重建地图，默认 0。           -->
  <!--                         如临时使用旧偏斜地图，可在命令行传入 -0.90。         -->
  <!--   map_translation_offset_x — 坐标变换后叠加的 X 轴平移量（米，默认 0）       -->
  <!--                              如临时使用旧偏斜地图，可传入 0.073。             -->
  <!--   map_translation_offset_y — 坐标变换后叠加的 Y 轴平移量（米，默认 0）       -->
  <!-- ============================================================ -->

  <!-- ── 1. 导航基础栈（复用原有 start_roscar.launch + AMCL）────── -->
  <arg name="map_file" default="$(find start_roscar)/map/roscar_map1.yaml"/>

  <!-- 硬件驱动：底盘、TF、EKF、激光雷达 -->
  <include file="$(find start_roscar)/launch/start_roscar.launch"/>

  <!-- 地图服务器 -->
  <node pkg="map_server" type="map_server" name="map_server_roscar"
        args="$(arg map_file)" output="screen"/>

  <!-- AMCL 定位 -->
  <include file="$(find start_roscar)/launch/include/amcl.launch"/>

  <!-- ── 2. move_base（绕障 fallback）──────────────────────────── -->
  <node pkg="move_base" type="move_base" name="move_base" output="screen">
    <!-- 直线导航专用 move_base 参数（planner_frequency 等微调） -->
    <rosparam command="load"
              file="$(find wulina)/param/straight_move_base_params.yaml"/>
    <!-- 全局代价地图（与原始相同，静态地图层） -->
    <rosparam command="load"
              file="$(find start_roscar)/param/global_costmap_params.yaml"/>
    <!-- 局部代价地图（与原始相同，滚动窗口） -->
    <rosparam command="load"
              file="$(find start_roscar)/param/local_costmap_params.yaml"/>
    <!-- 代价地图通用参数（脚印、障碍层、膨胀层） -->
    <rosparam command="load"
              file="$(find start_roscar)/param/costmap_common_params.yaml"/>
    <!-- 全局规划器参数（Dijkstra，与原始相同） -->
    <rosparam command="load"
              file="$(find start_roscar)/param/base_global_planner_param.yaml"/>
    <!-- 直线导航专用 TEB 参数（无后退，差速，权重最短路径） -->
    <rosparam command="load"
              file="$(find wulina)/param/straight_teb_params.yaml"/>
    <param name="transform_tolerance" value="1.0"/>
    <param name="use_sim_time"        value="false"/>
  </node>

  <!-- ── 3. 直线导航节点参数 ────────────────────────────────────── -->
  <arg name="loop"                      default="false"/>
  <arg name="loop_count"                default="1"/>
  <arg name="goal_timeout"              default="60.0"/>
  <arg name="interactive"               default="true"/>

  <!-- 运动控制参数 -->
  <arg name="linear_speed"              default="0.10"/>
  <arg name="angular_speed"             default="0.30"/>
  <arg name="yaw_tolerance"             default="0.05"/>
  <arg name="xy_goal_tolerance"         default="0.15"/>

  <!-- 障碍物检测参数 -->
  <arg name="obstacle_dist"             default="0.50"/>
  <arg name="obstacle_angle"            default="0.523"/>
  <arg name="heading_correct_threshold" default="0.20"/>

  <!-- 初始位姿参数 -->
  <arg name="set_initial_pose"          default="false"/>
  <arg name="initial_pose_x"            default="0.0"/>
  <arg name="initial_pose_y"            default="0.0"/>
  <arg name="initial_pose_a"            default="0.0"/>
  <arg name="amcl_wait_timeout"         default="30.0"/>
  <!-- 坐标系旋转偏差（弧度）                                                        -->
  <!-- robot_model_visualization.launch 已修正 base_to_laser TF（yaw +π/4），        -->
  <!-- 重建地图后两坐标系完全对齐，保持默认 0.0 即可。                               -->
  <!-- 注意：若尚未重建地图，仍在使用旧偏斜地图，请传入 map_rotation_offset:=-0.90  -->
  <!--       以及 map_translation_offset_x:=0.073 map_translation_offset_y:=0.328。 -->
  <arg name="map_rotation_offset"       default="0.0"/>
  <!-- 坐标系平移偏差（米）：重建地图后不需要；旧地图临时使用请见上方注释。         -->
  <arg name="map_translation_offset_x" default="0.0"/>
  <arg name="map_translation_offset_y" default="0.0"/>

  <!-- ── 4. 启动直线导航节点 ───────────────────────────────────── -->
  <node pkg="wulina" type="straight_line_nav.py"
        name="straight_line_nav" output="screen">
    <param name="loop"                      value="$(arg loop)"/>
    <param name="loop_count"                value="$(arg loop_count)"/>
    <param name="goal_timeout"              value="$(arg goal_timeout)"/>
    <param name="interactive"               value="$(arg interactive)"/>
    <param name="map_frame"                 value="map"/>
    <param name="base_frame"                value="base_footprint"/>
    <param name="linear_speed"              value="$(arg linear_speed)"/>
    <param name="angular_speed"             value="$(arg angular_speed)"/>
    <param name="yaw_tolerance"             value="$(arg yaw_tolerance)"/>
    <param name="xy_goal_tolerance"         value="$(arg xy_goal_tolerance)"/>
    <param name="obstacle_dist"             value="$(arg obstacle_dist)"/>
    <param name="obstacle_angle"            value="$(arg obstacle_angle)"/>
    <param name="heading_correct_threshold" value="$(arg heading_correct_threshold)"/>
    <param name="set_initial_pose"          value="$(arg set_initial_pose)"/>
    <param name="initial_pose_x"            value="$(arg initial_pose_x)"/>
    <param name="initial_pose_y"            value="$(arg initial_pose_y)"/>
    <param name="initial_pose_a"            value="$(arg initial_pose_a)"/>
    <param name="amcl_wait_timeout"         value="$(arg amcl_wait_timeout)"/>
    <param name="map_rotation_offset"       value="$(arg map_rotation_offset)"/>
    <param name="map_translation_offset_x"  value="$(arg map_translation_offset_x)"/>
    <param name="map_translation_offset_y"  value="$(arg map_translation_offset_y)"/>
  </node>

</launch>

<launch>
  <!-- Arguments参数 -->
  <arg name="car_mode"  default="" />
  
  <!-- 用于robot_state_publisher节点-->
  <node pkg="tf" type="static_transform_publisher" name="base_to_link" args="0 0 0 0 0 0 base_footprint base_link 100" />
  
  <!--坐标变换，需要实测 -->
  <!--阿克曼系列 -->
  <!-- car_mode and tf  senior_akm-->
  <group if="$(eval car_mode == 'senior_akm')">
   <node pkg="tf" type="static_transform_publisher" name="base_to_laser" args="0.26 0.00 0.228 3.14 0 0  base_footprint laser 100" />
   <node pkg="tf" type="static_transform_publisher" name="base_to_camera" args="0.34 0.00 0.178 0 0 0   base_footprint camera_link 100" />
   <node pkg="tf" type="static_transform_publisher" name="base_to_gyro" args="0 0 0 0 0 0 base_footprint gyro_link 100" />
  </group>


  <!--麦轮系列 -->
  <!-- car_mode and tf  senior_mec_bs-->
  <group if="$(eval car_mode == 'senior_mec_bs')">
      <node pkg="tf" type="static_transform_publisher" name="base_to_laser" args="0.12 0.00 0.165 3.14 0 0  base_footprint laser 100" />
      <node pkg="tf" type="static_transform_publisher" name="base_to_camera" args="0.18 0 0.115 0 0 0   base_footprint camera_link 100" />
      <node pkg="tf" type="static_transform_publisher" name="base_to_gyro" args="0 0 0 0 0 0 base_footprint gyro_link 100" />
  </group>
  <!-- car_mode and tf  senior_mec_dl-->
  <group if="$(eval car_mode == 'senior_mec_dl')">
      <node pkg="tf" type="static_transform_publisher" name="base_to_laser" args="0.18 0.00 0.32 3.14 0 0  base_footprint laser 100" />
      <node pkg="tf" type="static_transform_publisher" name="base_to_camera" args="0.240 0 0.27 0 0 0   base_footprint camera_link 100" />
      <node pkg="tf" type="static_transform_publisher" name="base_to_gyro" args="0 0 0 0 0 0 base_footprint gyro_link 100" />
  </group>


 <!--全向轮系列 -->
 <!-- car_mode and tf  mini_omni-->
 <group if="$(eval car_mode == 'mini_omni')">
      <node pkg="tf" type="static_transform_publisher" name="base_to_laser" args="0.015 0.00 0.17 3.14 0 0  base_footprint laser 100" />
      <node pkg="tf" type="static_transform_publisher" name="base_to_camera" args="0.075 0.00 0.12 0 0 0   base_footprint camera_link 100" />
      <node pkg="tf" type="static_transform_publisher" name="base_to_gyro" args="0 0 0 0 0 0 base_footprint gyro_link 100" />
  </group>
  <!-- car_mode and tf  senior_omni-->
  <group if="$(eval car_mode == 'senior_omni')">
      <node pkg="tf" type="static_transform_publisher" name="base_to_laser" args="0.09 0.00 0.25 3.14 0 0  base_footprint laser 100" />
      <node pkg="tf" type="static_transform_publisher" name="base_to_camera" args="0.15 0.00 0.20 0 0 0   base_footprint camera_link 100" />
      <node pkg="tf" type="static_transform_publisher" name="base_to_gyro" args="0 0 0 0 0 0 base_footprint gyro_link 100" />
  </group>
  <!-- car_mode and tf  top_omni-->
  <group if="$(eval car_mode == 'top_omni')">
      <node pkg="tf" type="static_transform_publisher" name="base_to_laser" args="0.18 0.00 0.28 3.14 0 0  base_footprint laser 100" />
      <node pkg="tf" type="static_transform_publisher" name="base_to_camera" args="0.24 0.00 0.23 0 0 0   base_footprint camera_link 100" />
      <node pkg="tf" type="static_transform_publisher" name="base_to_gyro" args="0 0 0 0 0 0 base_footprint gyro_link 100" />
  </group>


  <!--差速系列 -->
  <!-- car_mode and tf  senior_diff-->
  <!-- 激光雷达0°方向与车头不在一条直线上，物理安装偏差+45°（逆时针）。          -->
  <!-- 在 yaw（绕Z轴旋转角）上叠加 +π/4（0.7854 rad），使 TF 与实际安装吻合。   -->
  <!-- 旧值：3.14（≈π），新值：3.93（≈5π/4，精确值 3.9270）；修正后重建地图。  -->
  <group if="$(eval car_mode == 'senior_diff')">
      <node pkg="tf" type="static_transform_publisher" name="base_to_laser" args="0.23 0.00 0.20 3.93 0 0  base_footprint laser 100" />
      <node pkg="tf" type="static_transform_publisher" name="base_to_camera" args="0.29 0.00 0.15 0 0 0   base_footprint camera_link 100" />
      <node pkg="tf" type="static_transform_publisher" name="base_to_gyro" args="0 0 0 0 0 0 base_footprint gyro_link 100" />
  </group>
 
  <!-- URDF 标准化机器人描述格式 -->
  <!--阿克曼系列 -->
  <group if="$(eval car_mode == 'mini_akm')">
      <param name = "robot_description" textfile = "$(find start_roscar)/urdf/mini_akm_robot.urdf"/> 
  </group>
  <group if="$(eval car_mode == 'senior_akm')">
      <param name = "robot_description" textfile = "$(find start_roscar)/urdf/senior_akm_robot.urdf"/> 
  </group>
  <group if="$(eval car_mode == 'top_akm_bs')">
      <param name = "robot_description" textfile = "$(find start_roscar)/urdf/top_akm_bs_robot.urdf"/> 
  </group>
  <group if="$(eval car_mode == 'top_akm_dl')">
      <param name = "robot_description" textfile = "$(find start_roscar)/urdf/top_akm_dl_robot.urdf"/> 
  </group>

  <!--麦轮系列 -->
  <group if="$(eval car_mode == 'mini_mec')">
      <param name = "robot_description" textfile = "$(find start_roscar)/urdf/mini_mec_robot.urdf"/> 
  </group>
  <group if="$(eval car_mode == 'mini_mec_moveit')">
      <param name = "robot_description" textfile = "$(find start_roscar)/urdf/mini_mec_moveit.urdf"/> 
  </group>
  <group if="$(eval car_mode == 'senior_mec_bs')">
      <param name = "robot_description" textfile = "$(find start_roscar)/urdf/senior_mec_robot.urdf"/> 
  </group>
  <group if="$(eval car_mode == 'senior_mec_dl')">
      <param name = "robot_description" textfile = "$(find start_roscar)/urdf/senior_mec_dl_robot.urdf"/> 
  </group>
  <group if="$(eval car_mode == 'top_mec_bs')">
      <param name = "robot_description" textfile = "$(find start_roscar)/urdf/top_mec_bs_robot.urdf"/> 
  </group>
  <group if="$(eval car_mode == 'top_mec_dl')">
      <param name = "robot_description" textfile = "$(find start_roscar)/urdf/top_mec_dl_robot.urdf"/> 
  </group>
  <group if="$(eval car_mode == 'senior_mec_EightDrive' or car_mode == 'top_mec_EightDrive')">
      <param name = "robot_description" textfile = "$(find start_roscar)/urdf/mec_EightDrive_robot.urdf"/> 
  </group>
  <group if="$(eval car_mode == 'flagship_mec_dl')">
      <param name = "robot_description" textfile = "$(find start_roscar)/urdf/flagship_mec_dl_robot.urdf"/> 
  </group>
  <group if="$(eval car_mode == 'flagship_mec_bs')">
      <param name = "robot_description" textfile = "$(find start_roscar)/urdf/flagship_mec_bs_robot.urdf"/> 
  </group>

  <!--全向轮系列 -->
  <group if="$(eval car_mode == 'mini_omni')">
      <param name = "robot_description" textfile = "$(find start_roscar)/urdf/mini_omni_robot.urdf"/> 
  </group>
  <group if="$(eval car_mode == 'senior_omni')">
      <param name = "robot_description" textfile = "$(find start_roscar)/urdf/senior_omni_robot.urdf"/> 
  </group>
  <group if="$(eval car_mode == 'top_omni')">
      <param name = "robot_description" textfile = "$(find start_roscar)/urdf/top_omni_robot.urdf"/> 
  </group>

  <!--四驱系列 -->
  <group if="$(eval car_mode == 'senior_4wd_bs')">
      <param name = "robot_description" textfile = "$(find start_roscar)/urdf/senior_4wd_bs_robot.urdf"/> 
  </group>
  <group if="$(eval car_mode == 'senior_4wd_dl')">
      <param name = "robot_description" textfile = "$(find start_roscar)/urdf/senior_4wd_dl_robot.urdf"/> 
  </group>
  <group if="$(eval car_mode == 'top_4wd_bs')">
      <param name = "robot_description" textfile = "$(find start_roscar)/urdf/top_4wd_bs_robot.urdf"/> 
  </group>
  <group if="$(eval car_mode == 'top_4wd_dl')">
      <param name = "robot_description" textfile = "$(find start_roscar)/urdf/top_4wd_dl_robot.urdf"/> 
  </group>
  <group if="$(eval car_mode == 'flagship_4wd_bs')">
      <param name = "robot_description" textfile = "$(find start_roscar)/urdf/flagship_4wd_bs_robot.urdf"/> 
  </group>
  <group if="$(eval car_mode == 'flagship_4wd_dl')">
      <param name = "robot_description" textfile = "$(find start_roscar)/urdf/flagship_4wd_dl_robot.urdf"/> 
  </group>
  <group if="$(eval car_mode == 'mini_4wd')">
      <param name = "robot_description" textfile = "$(find start_roscar)/urdf/mini_4wd_robot.urdf"/> 
  </group>
  <group if="$(eval car_mode == 'mini_4wd_moveit')">
      <param name = "robot_description" textfile = "$(find start_roscar)/urdf/mini_4wd_moveit.urdf"/> 
  </group>

  <!--差速系列 -->
  <group if="$(eval car_mode == 'mini_tank')">
      <param name = "robot_description" textfile = "$(find start_roscar)/urdf/mini_4wd_robot.urdf"/> 
  </group>
  <group if="$(eval car_mode == 'mini_tank_moveit')">
      <param name = "robot_description" textfile = "$(find start_roscar)/urdf/mini_tank_moveit.urdf"/> 
  </group>
  <group if="$(eval car_mode == 'mini_diff')">
      <param name = "robot_description" textfile = "$(find start_roscar)/urdf/mini_diff_robot.urdf"/> 
  </group>
  <group if="$(eval car_mode == 'senior_diff')">
      <param name = "robot_description" textfile = "$(find start_roscar)/urdf/senior_diff_robot.urdf"/> 
  </group>
  <group if="$(eval car_mode == 'four_wheel_diff_bs')">
      <param name = "robot_description" textfile = "$(find start_roscar)/urdf/four_wheel_diff_bs_robot.urdf"/> 
  </group>
  <group if="$(eval car_mode == 'four_wheel_diff_dl')">
      <param name = "robot_description" textfile = "$(find start_roscar)/urdf/four_wheel_diff_dl_robot.urdf"/> 
  </group>
  <group if="$(eval car_mode == 'flagship_four_wheel_diff_dl')">
      <param name = "robot_description" textfile = "$(find start_roscar)/urdf/flagship_four_wheel_diff_dl_robot.urdf"/>
  </group>
  <group if="$(eval car_mode == 'flagship_four_wheel_diff_bs')">
      <param name = "robot_description" textfile = "$(find start_roscar)/urdf/flagship_four_wheel_diff_bs_robot.urdf"/>
  </group>
  <group if="$(eval car_mode == 'brushless_senior_diff')">
      <param name = "robot_description" textfile = "$(find start_roscar)/urdf/brushless_senior_diff.urdf"/> 
  </group>
  
  <!-- 读取urdf信息(robot_description) 发布话题：/joint_states-->
  <node name="joint_state_publisher" pkg="joint_state_publisher" type="joint_state_publisher" />
  <!-- 订阅话题：/joint_states，发布小车TF信息-->
  <node name="robot_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher" />

 </launch>


